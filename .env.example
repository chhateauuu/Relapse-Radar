# Relapse Radar — backend secrets (P3). Copy to `.env` and fill in.
# `.env` is gitignored — never commit real creds.

# --- Twilio (the real escalation SMS) ---
# From https://console.twilio.com — without these the API runs in SIMULATED mode
# (the EscalationEvent is still built, only the wire-send is skipped).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- LLM explanation (optional) ---
# Without OPENAI_API_KEY the LLM layer composes the sentence locally (offline).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
